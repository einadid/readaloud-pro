{
  "manifest_version": 3,
  "name": "ReadAloud Pro",
  "version": "3.1",
  "description": "Read selected text aloud (Bangla + English)",
  
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus",
    "storage"
  ],
  
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "ReadAloud",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  }
}